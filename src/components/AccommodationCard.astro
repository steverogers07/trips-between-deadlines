---
import { formatCurrency, t } from '../i18n/utils';
import type { Locale } from '../i18n/config';

interface Props {
  accommodation: {
    name: string;
    costPerNight: number;
    rating: number;
    bookingLink?: string;
    mapsLink?: string;
    pros: string[];
    cons: string[];
  };
  currency: string;
  locale: Locale;
}

const { accommodation, currency, locale } = Astro.props;
const { name, costPerNight, rating, bookingLink, mapsLink, pros, cons } = accommodation;

const stars = Array.from({ length: 5 }, (_, i) => i < rating);
---

<div class="bg-white rounded-2xl p-6 shadow-sm">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
    <div>
      <h4 class="text-lg font-bold text-charcoal">{name}</h4>
      <div class="flex items-center gap-1 mt-1">
        {stars.map((filled) => (
          <svg
            class:list={['w-4 h-4', filled ? 'text-yellow-400' : 'text-gray-300']}
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
      </div>
      <p class="mt-2 text-primary font-bold text-lg">
        {formatCurrency(costPerNight, currency)}<span class="text-sm font-normal text-charcoal-light">{t(locale, 'trip.perNight')}</span>
      </p>
    </div>

    <div class="flex gap-2 shrink-0">
      {bookingLink && (
        <a
          href={bookingLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm text-primary hover:underline"
        >
          🔗 {t(locale, 'trip.bookNow')}
        </a>
      )}
      {mapsLink && (
        <a
          href={mapsLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm text-accent hover:underline"
        >
          📍 {t(locale, 'trip.viewOnMap')}
        </a>
      )}
    </div>
  </div>

  {(pros.length > 0 || cons.length > 0) && (
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4 pt-4 border-t border-gray-100">
      {pros.length > 0 && (
        <div>
          <h5 class="text-sm font-semibold text-accent mb-2">✅ Pros</h5>
          <ul class="space-y-1">
            {pros.map((pro) => (
              <li class="text-sm text-charcoal-light flex items-start gap-2">
                <span class="text-accent mt-0.5 shrink-0">+</span> {pro}
              </li>
            ))}
          </ul>
        </div>
      )}
      {cons.length > 0 && (
        <div>
          <h5 class="text-sm font-semibold text-red-500 mb-2">❌ Cons</h5>
          <ul class="space-y-1">
            {cons.map((con) => (
              <li class="text-sm text-charcoal-light flex items-start gap-2">
                <span class="text-red-500 mt-0.5 shrink-0">−</span> {con}
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  )}
</div>

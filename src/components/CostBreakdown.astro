---
import { formatCurrency } from '../i18n/utils';
import type { Locale } from '../i18n/config';
import { t } from '../i18n/utils';

interface Props {
  breakdown: {
    accommodation: number;
    food: number;
    transport: number;
    activities: number;
    misc: number;
  };
  currency: string;
  totalCost: number;
  locale: Locale;
}

const { breakdown, currency, totalCost, locale } = Astro.props;

const categories = [
  { key: 'accommodation', label: '🏨 Accommodation', amount: breakdown.accommodation, color: 'bg-primary' },
  { key: 'food', label: '🍽️ Food & Drinks', amount: breakdown.food, color: 'bg-accent' },
  { key: 'transport', label: '🚗 Transport', amount: breakdown.transport, color: 'bg-blue-500' },
  { key: 'activities', label: '🎯 Activities', amount: breakdown.activities, color: 'bg-purple-500' },
  { key: 'misc', label: '📦 Miscellaneous', amount: breakdown.misc, color: 'bg-gray-500' },
];
---

<div class="bg-white rounded-2xl p-6 shadow-sm">
  <h3 class="text-xl font-bold text-charcoal mb-6 flex items-center gap-2">
    💰 {t(locale, 'trip.costBreakdown')}
  </h3>

  <div class="space-y-4">
    {categories.map((cat) => {
      const pct = totalCost > 0 ? Math.round((cat.amount / totalCost) * 100) : 0;
      return (
        <div>
          <div class="flex items-center justify-between mb-1.5">
            <span class="text-sm font-medium text-charcoal">{cat.label}</span>
            <span class="text-sm font-semibold text-charcoal">
              {formatCurrency(cat.amount, currency)}
            </span>
          </div>
          <div class="w-full bg-gray-100 rounded-full h-2.5 overflow-hidden">
            <div
              class:list={[cat.color, 'h-full rounded-full transition-all duration-700']}
              style={`width: ${pct}%`}
            />
          </div>
          <span class="text-xs text-charcoal-light mt-0.5 block">{pct}%</span>
        </div>
      );
    })}
  </div>

  <div class="mt-6 pt-4 border-t border-gray-100 flex items-center justify-between">
    <span class="font-semibold text-charcoal">Total</span>
    <span class="text-xl font-bold text-primary">
      {formatCurrency(totalCost, currency)}
    </span>
  </div>
</div>

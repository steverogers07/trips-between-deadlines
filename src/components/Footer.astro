---
import { t, getLocalizedPath } from '../i18n/utils';
import type { Locale } from '../i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const links = [
  { href: getLocalizedPath('/', locale), label: t(locale, 'nav.home') },
  { href: getLocalizedPath('/journal', locale), label: t(locale, 'nav.journal') },
  { href: getLocalizedPath('/about', locale), label: t(locale, 'nav.about') },
];

const year = new Date().getFullYear();
---

<footer class="bg-charcoal text-gray-300 mt-auto">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <a href={getLocalizedPath('/', locale)} class="flex items-center gap-2 mb-3">
          <span class="text-2xl">✈️</span>
          <span class="font-bold text-lg text-white">Trips Between Deadlines</span>
        </a>
        <p class="text-sm text-gray-400">{t(locale, 'footer.tagline')}</p>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">
          {t(locale, 'footer.quickLinks')}
        </h3>
        <ul class="space-y-2">
          {links.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-primary-light transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">
          {t(locale, 'footer.connect')}
        </h3>
        <div class="flex gap-3">
          <a href="https://www.instagram.com/divyansh1792" target="_blank" rel="noopener noreferrer"

    </div>

    <div class="mt-8 pt-8 border-t border-white/10 text-center">
      <p class="text-sm text-gray-500">
        &copy; {year} Trips Between Deadlines. {t(locale, 'footer.madeWith')} ☕ &amp; Astro.
      </p>
    </div>
  </div>

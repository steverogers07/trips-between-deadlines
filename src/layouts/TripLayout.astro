---
import BaseLayout from './BaseLayout.astro';
import CostBreakdown from '../components/CostBreakdown.astro';
import AccommodationCard from '../components/AccommodationCard.astro';
import PhotoGallery from '../components/PhotoGallery';
import ShareButtons from '../components/ShareButtons.astro';
import TripCard from '../components/TripCard.astro';
import { t, formatCurrency, estimateReadingTime } from '../i18n/utils';
import type { Locale } from '../i18n/config';
import type { Trip } from '../lib/trips';
import { getRelatedTrips } from '../lib/trips';
import { render } from 'astro:content';

interface Props {
  trip: Trip;
  locale: Locale;
}

const { trip, locale } = Astro.props;
const { data } = trip;
const { title, description, date, location, duration, totalCost, currency, coverImage, gallery, category, accommodation, costBreakdown, tags } = data;

const { Content } = await render(trip);
const readingTime = estimateReadingTime(trip.body ?? '');
const related = await getRelatedTrips(trip, locale);
const pageUrl = Astro.url.href;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  image: new URL(coverImage, Astro.site).href,
  datePublished: date.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Divyansh Singh',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Trips Between Deadlines',
  },
};
---

<BaseLayout title={title} description={description} image={coverImage} article={true} jsonLd={jsonLd}>
  <section class="relative h-[50vh] sm:h-[60vh] overflow-hidden">
    <img
      src={coverImage}
      alt={title}
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 p-6 sm:p-8 lg:p-12">
      <div class="max-w-4xl mx-auto">
        <span class:list={[
          'inline-block px-3 py-1 text-xs font-semibold rounded-full uppercase tracking-wide mb-4',
          category === 'india' ? 'bg-accent text-white' : 'bg-primary text-white',
        ]}>
          {category === 'india' ? '🇮🇳 India' : '🌍 International'}
        </span>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight">
          {title}
        </h1>
        <div class="flex flex-wrap items-center gap-3 mt-4 text-gray-300 text-sm">
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {location}
          </span>
          <span class="text-white/30">|</span>
          <span>{formattedDate}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white border-b border-gray-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="flex flex-wrap gap-4 sm:gap-8">
          <div class="text-center">
            <p class="text-xs uppercase tracking-wide text-charcoal-light">{t(locale, 'trip.duration')}</p>
            <p class="text-lg font-bold text-charcoal">{duration}</p>
          </div>
          <div class="text-center">
            <p class="text-xs uppercase tracking-wide text-charcoal-light">Read</p>
            <p class="text-lg font-bold text-charcoal">{readingTime} {t(locale, 'trip.readingTime')}</p>
          </div>
        </div>
        <ShareButtons url={pageUrl} title={title} locale={locale} />
      </div>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <article class="prose prose-lg max-w-none
                     prose-headings:text-charcoal
                     prose-a:text-primary
                     prose-img:rounded-xl prose-img:shadow-sm
                     prose-blockquote:border-primary/50">
      <Content />
    </article>

    {costBreakdown && (
      <div class="mt-12">
        <CostBreakdown
          breakdown={costBreakdown}
          currency={currency}
          totalCost={totalCost}
          locale={locale}
        />
      </div>
    )}

    {accommodation.length > 0 && (
      <div class="mt-12">
        <h2 class="text-2xl font-bold text-charcoal mb-6 flex items-center gap-2">
          🏨 {t(locale, 'trip.accommodation')}
        </h2>
        <div class="space-y-4">
          {accommodation.map((acc) => (
            <AccommodationCard accommodation={acc} currency={currency} locale={locale} />
          ))}
        </div>
      </div>
    )}

    {gallery.length > 0 && (
      <div class="mt-12">
        <h2 class="text-2xl font-bold text-charcoal mb-6 flex items-center gap-2">
          📸 {t(locale, 'trip.gallery')}
        </h2>
        <PhotoGallery images={gallery} title={title} client:visible />
      </div>
    )}

    {tags.length > 0 && (
      <div class="mt-10 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="px-3 py-1 text-sm rounded-full bg-charcoal/5 text-charcoal-light">
            #{tag}
          </span>
        ))}
      </div>
    )}

    {related.length > 0 && (
      <div class="mt-14 pt-10 border-t border-gray-100">
        <h2 class="text-2xl font-bold text-charcoal mb-6">
          {t(locale, 'trip.related')}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {related.map((r) => (
            <TripCard trip={r} locale={locale} />
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>

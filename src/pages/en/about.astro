---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllTrips } from '../../lib/trips';
import { t, getLocalizedPath } from '../../i18n/utils';
import type { Locale } from '../../i18n/config';

const locale: Locale = 'en';
const allTrips = await getAllTrips(locale);
const uniqueDestinations = new Set(allTrips.map((t) => t.data.location)).size;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About - Trips Between Deadlines',
  description: 'About Divyansh Singh — a tech professional who documents his travel experiences.',
};
---

<BaseLayout title={t(locale, 'about.title')} jsonLd={jsonLd}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <h1 class="text-2xl font-bold text-charcoal">
      About this blog
    </h1>

    <p class="mt-3 text-sm text-charcoal-light">
      {allTrips.length} {allTrips.length === 1 ? 'trip' : 'trips'} logged · {uniqueDestinations} {uniqueDestinations === 1 ? 'place' : 'places'} visited
    </p>

    <div class="mt-12 space-y-6 text-charcoal-light leading-relaxed text-lg">
      <p>
        I'm not a full-time travel blogger. I'm not a digital nomad. I'm a regular 9-to-5 tech professional
        who squeezes trips between deadlines — long weekends, public holidays, and the occasional
        PTO stretch.
      </p>

      <p>
        This blog exists because every time I plan a trip, I spend hours searching Reddit, blogs,
        and YouTube for the same basic questions: <em>Where did you stay? How much did it actually cost?
        What would you do differently?</em>
      </p>

      <p>
        Most of what I find is either outdated, vague, or written by people whose budgets don't match
        mine. So I started documenting my own trips — with real numbers, honest reviews, and the stuff
        I wish someone had told me before I went.
      </p>

      <h2 class="text-2xl font-bold text-charcoal pt-4">What you'll find here</h2>

      <ul class="space-y-3">
        <li class="flex items-start gap-3">
          <span class="text-primary mt-0.5">💰</span>
          <span><strong class="text-charcoal">Real cost breakdowns</strong> — every rupee and dollar accounted for, from stay to chai.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary mt-0.5">🏨</span>
          <span><strong class="text-charcoal">Honest accommodation reviews</strong> — with booking links and Google Maps pins, so you can check them out yourself.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary mt-0.5">🔄</span>
          <span><strong class="text-charcoal">"What I'd do differently"</strong> — because hindsight is useful, and I can't just redo the trip next month.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary mt-0.5">📸</span>
          <span><strong class="text-charcoal">Photos from the trip</strong> — no stock images, just what I actually saw.</span>
        </li>
      </ul>

      <h2 class="text-2xl font-bold text-charcoal pt-4">No sponsorships. No fluff.</h2>

      <p>
        Everything on this blog is self-funded and based on my actual experience. When I recommend a stay
        or a route, it's because I genuinely liked it — not because someone paid me to say it.
      </p>

      <p>
        If my notes help even one person plan their trip better, this blog has served its purpose.
      </p>
    </div>

    <div class="mt-12 pt-8 border-t border-charcoal/10">
      <p class="text-charcoal-light">
        Want to read the actual trip notes?{' '}
        <a
          href={getLocalizedPath('/journal', locale)}
          class="text-primary hover:underline"
        >
          Head to the journal →
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
